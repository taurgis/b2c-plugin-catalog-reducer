{
  "name": "b2c-plugin-catalog-reducer",
  "version": "1.0.0",
  "description": "Catalog reducer for Salesforce B2C Commerce XML datasets.",
  "author": "Thomas Theunen",
  "bin": {
    "catalog-reducer": "./bin/run.js"
  },
  "main": "dist/index.js",
  "files": [
    "bin",
    "dist",
    "lib",
    "reducer.js",
    "xsd"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./bin/run.js catalog reduce",
    "reduce": "node ./bin/run.js catalog reduce",
    "lint:root": "eslint \"src/**/*.ts\" \"bin/**/*.js\" \"scripts/**/*.js\" reducer.js \"lib/**/*.js\" \"test/**/*.js\"",
    "lint": "npm run lint:root",
    "test:root": "vitest run",
    "test": "npm run test:root && node --test test/**/*.test.js",
    "test:coverage": "npm run test:root && c8 --all --check-coverage --per-file --lines 75 --branches 60 --statements 75 --exclude='test/**' --include='reducer.js' --include='lib/**/*.js' node --test test/**/*.test.js",
    "test:ci": "npm run lint && npm run test:coverage"
  },
  "dependencies": {
    "@oclif/core": "^4.8.1",
    "@oclif/plugin-help": "^6.0.28",
    "@oclif/plugin-plugins": "^5.4.43",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "config": "^3.3.12",
    "node-expat": "^2.4.1",
    "xml-flow": "^1.0.4",
    "xml-formatter": "^2.6.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "c8": "^10.1.3",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "b2c",
    "sfcc",
    "catalog",
    "reducer",
    "xml",
    "fixtures"
  ],
  "oclif": {
    "additionalHelpFlags": [
      "-h"
    ],
    "bin": "catalog-reducer",
    "commands": "./dist/commands",
    "dirname": "catalog-reducer",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  }
}
